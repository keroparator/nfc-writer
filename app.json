{
  "expo": {
    "name": "nfc-writer",
    "slug": "nfc-writer",
    "version": "0.0.9.2",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.anonymous.nfc_writer",
      "permissions": [
        "android.permission.NFC"
      ]
    },
    "plugins": [
      [
        "react-native-nfc-manager",
        {
          "nfcPermissionAndroid": "Uygulama NFC kartları okumak ve yazmak için izin istiyor."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0f75e265-3f6c-45b9-9819-d31c94209793"
      }
    }
  }
}
